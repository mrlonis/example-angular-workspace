{
  "name": "example-angular-workspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "ng build",
    "build:all": "npm run build -- lib && npm run build -- input && npm run build -- paginator && npm run build -- table && npm run build -- app",
    "lint": "ng lint",
    "lint:ci": "npm run lint && npm run lint:playwright",
    "lint:fix": "npm run lint -- --fix && npm run lint:playwright -- --fix",
    "lint:playwright": "eslint -c ./tests/eslint.config.js ./tests",
    "ng": "ng",
    "prepare": "husky",
    "prettier": "prettier --write . --ignore-unknown",
    "prettier:test": "prettier --check . --ignore-unknown",
    "start": "ng serve",
    "sync:agent-instructions": "node scripts/sync-agent-instructions.mjs",
    "sync:agent-instructions:check": "node scripts/sync-agent-instructions.mjs --check",
    "test": "ng test",
    "test:ci": "npm run test:unit && npm run test:e2e:ci",
    "test:e2e": "playwright test --config='./tests/playwright.config.ts'",
    "test:e2e:ci": "playwright install chromium && playwright test --project=chromium --config='./tests/playwright.config.ts' --reporter=line",
    "test:unit": "npm run test -- --no-watch --coverage --coverage-reporters html --coverage-reporters lcov --coverage-reporters text --coverage-reporters text-summary",
    "watch": "ng build --watch --configuration development"
  },
  "lint-staged": {
    "{package.json,projects/**/package.json}": [
      "sort-package-json",
      "prettier --write"
    ],
    "projects/app/**/*.{html,ts}": [
      "ng-lint-staged lint app --fix --"
    ],
    "projects/input/**/*.{html,ts}": [
      "ng-lint-staged lint input --fix --"
    ],
    "projects/lib/**/*.{html,ts}": [
      "ng-lint-staged lint lib --fix --"
    ],
    "projects/paginator/**/*.{html,ts}": [
      "ng-lint-staged lint paginator --fix --"
    ],
    "projects/table/**/*.{html,ts}": [
      "ng-lint-staged lint table --fix --"
    ],
    "tests/**/*.ts": [
      "eslint -c ./tests/eslint.config.js ./tests --fix"
    ],
    "!({package.json,projects/**/package.json,projects/app/**/*.{html,ts},projects/lib/**/*.{html,ts},projects/paginator/**/*.{html,ts},projects/table/**/*.{html,ts},tests/**/*.ts})": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@angular/cdk": "^22",
    "@angular/common": "^22",
    "@angular/compiler": "^22",
    "@angular/core": "^22",
    "@angular/forms": "^22",
    "@angular/material": "^22",
    "@angular/platform-browser": "^22",
    "@angular/router": "^22",
    "rxjs": "^7",
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/build": "^22",
    "@angular/cli": "^22",
    "@angular/compiler-cli": "^22",
    "@eslint/js": "^9",
    "@playwright/test": "^1",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^4",
    "angular-eslint": "^22",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-import": "^2",
    "eslint-plugin-prettier": "^5",
    "husky": "^9",
    "jsdom": "^29",
    "lint-staged": "^17",
    "ng-lint-staged": "^12",
    "ng-packagr": "^22",
    "prettier": "^3",
    "sort-package-json": "^4",
    "typescript": "~6.0",
    "typescript-eslint": "^8",
    "vitest": "^4"
  },
  "packageManager": "npm@11.16.0",
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true,
    "unrs-resolver@1.12.2": true
  }
}
