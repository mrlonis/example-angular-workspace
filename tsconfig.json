/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "paths": {
      "input": ["./dist/input"],
      "lib": ["./dist/lib"],
      "paginator": ["./dist/paginator"],
      "table": ["./dist/table"]
    },
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/app/tsconfig.app.json"
    },
    {
      "path": "./projects/app/tsconfig.spec.json"
    },
    {
      "path": "./projects/lib/tsconfig.lib.json"
    },
    {
      "path": "./projects/lib/tsconfig.spec.json"
    },
    {
      "path": "./projects/table/tsconfig.lib.json"
    },
    {
      "path": "./projects/table/tsconfig.spec.json"
    },
    {
      "path": "./projects/input/tsconfig.lib.json"
    },
    {
      "path": "./projects/input/tsconfig.spec.json"
    },
    {
      "path": "./tests/tsconfig.json"
    },
    {
      "path": "./projects/paginator/tsconfig.lib.json"
    },
    {
      "path": "./projects/paginator/tsconfig.spec.json"
    }
  ]
}
